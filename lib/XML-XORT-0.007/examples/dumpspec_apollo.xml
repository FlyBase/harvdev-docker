          <feature>
              <type_id>
                 <cvterm>
                     <name><or>mRNA</or><or>pseudogene</or><or>ncRNA</or><or>snRNA</or><or>snoRNA</or><or>tRNA</or><or>rRNA</or><or>miRNA</or></name>
                 </cvterm>
              </type_id>
          </feature>
       </subject_id>
       <subject_id>
          <feature dump="all">  
              <!-- get all exon of those mRNA --> 
              <feature_relationship dump="cols">
                 <subject_id test="yes">
                     <feature>
                        <type_id>
                           <cvterm>
                               <name>exon</name>
                           </cvterm>                     
                        </type_id>
                     </feature>
                 </subject_id>
                 <subject_id>
                     <feature dump="all">
                       <!-- DO NOT dump evidence for exon -->
                       <prediction_evidence dump="no_dump"/>
                       <alignment_evidence dump="no_dump"/>
                       <scaffold_feature dump="no_dump" />
                       <gene_syntenic_block dump="no_dump"/>

                       <!-- The following link-tables have NO records for exons for Apollo data -->
                       <feature_pub dump="no_dump"/>
                       <feature_cvterm dump="no_dump"/>
                       <feature_genotype dump="no_dump"/>
                       <feature_phenotype dump="no_dump"/>
                       <analysisfeature dump="no_dump"/>
                       <feature_expression dump="no_dump"/>
                       <featurerange dump="no_dump"/>
                       <featurepos dump="no_dump"/>
                       <library_feature dump="no_dump"/>

                       <!-- NO dump of feature_relationship, otherwise will cause endless loop -->
                       <feature_relationship dump="no_dump" />
                       <featureslice dump="no_dump" />
                        <!-- for srcfeature of exon/protein/gene will be ARM, it will NOT dump residues -->
                       <featureloc dump="cols">
                            <srcfeature_id>
                               <feature dump="select">
                                  <uniquename/>
                                  <organism_id/>
                                  <type_id>
                                     <cvterm dump="cols"/>
                                  </type_id>
                               </feature>
                            </srcfeature_id>
                       </featureloc>

                      <!-- so also keep track of synonym.synonym_sgml -->
                      <feature_synonym dump="cols">
                          <synonym_id>
                             <synonym dump="cols"/>
                          </synonym_id>
                      </feature_synonym>

                      <!-- add this to track the ownship of each featureprop -->
                      <featureprop dump="cols">
                          <featureprop_pub dump="cols"/>
                      </featureprop>

                      <!-- also dump GO for exon -->
                      <feature_cvterm dump="cols">
                          <cvterm_id>
                             <cvterm dump="cols"/>
                          </cvterm_id>
                         <feature_cvtermprop/>
                      </feature_cvterm>

                    </feature>
                 </subject_id>
             </feature_relationship>



             <!-- get all protein of those mRNA --> 
              <feature_relationship dump="cols">
                 <subject_id test="yes">
                     <feature>
                        <type_id>
                           <cvterm>
                               <name>protein</name>
                           </cvterm>                     
                        </type_id>
                     </feature>
                 </subject_id>
