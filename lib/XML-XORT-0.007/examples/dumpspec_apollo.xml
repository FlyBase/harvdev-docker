             <featureloc dump="cols">
                            <srcfeature_id>
                               <feature dump="select">
                                  <uniquename/>
                                  <organism_id/>
                                  <type_id>
                                     <cvterm dump="cols"/>
                                  </type_id>
                               </feature>
                            </srcfeature_id>
             </featureloc>
