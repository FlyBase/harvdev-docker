 <!-- dump all alignment_evidence, with function featuresplice , here also get all those overlap with scaffold, e.g BAC clone -->
 <!-- here we filter out residues for certain feature with huge sequence -->
 <feature dump="cols">
   <_sql>select feature_0.feature_id, feature_0.uniquename,feature_0.name,feature_0.type_id,feature_0.organism_id, feature_0.residues,feature_0.is_analysis,feature_0.seqlen,feature_0.md5checksum,feature_0.timeaccessioned ,feature_0.timelastmodified,feature_0.dbxref_id from feature feature_0, featureslice($2, $3) featureloc_0, feature_relationship feature_relationship_0, cvterm cvterm_0, analysisfeature analysisfeature_0, analysis analysis_0 where feature_0.type_id=cvterm_0.cvterm_id and cvterm_0.name='match' and feature_0.feature_id=analysisfeature_0.feature_id and analysisfeature_0.analysis_id=analysis_0.analysis_id and (analysis_0.sourcename &lt;&gt;'na_baylorf1_scfchunk.dpse' and analysis_0.sourcename&lt;&gt;'na_scf_chunk_agambiae.fa' ) and feature_0.feature_id=feature_relationship_0.object_id and feature_relationship_0.subject_id=featureloc_0.feature_id and featureloc_0.srcfeature_id=$1   group by feature_0.feature_id</_sql>

   <analysisfeature dump="cols">
       <analysis_id>
          <analysis dump="cols"/>
       </analysis_id>
   </analysisfeature>
   <feature_relationship dump="all">
       <subject_id>
           <feature dump="select">
              <analysisfeature dump="cols">
                    <analysis_id>
                       <analysis dump="cols"/>
                   </analysis_id>
              </analysisfeature>
              <featureloc dump="cols">
                 <rank test="yes">1</rank>
                 <srcfeature_id>
                     <feature dump="cols">                       
                       	  <feature_dbxref dump="cols">
	                      <dbxref_id >
                                 <dbxref dump="cols"/>
                              </dbxref_id>
	                  </feature_dbxref>
                          <featureprop dump="cols"/>
                     </feature>
                 </srcfeature_id>
              </featureloc>
              <featureloc dump="cols">
                 <rank test="yes">0</rank>
                 <srcfeature_id>
                     <feature dump="select">
                          <uniquename/>
                          <dbxref_id/>
                          <organism_id/>
                          <type_id/>
                       	  <feature_dbxref dump="cols">
	                      <dbxref_id >
                                 <dbxref dump="cols"/>
                              </dbxref_id>
	                  </feature_dbxref>
                     </feature>
                 </srcfeature_id>
              </featureloc>
               <!--why this extra featureloc here, seems it return nothing because ambiguity of link-key -->
              <featureloc dump="cols">
                <rank test="yes">0</rank>
              </featureloc>
           </feature>
       </subject_id>
   </feature_relationship>
 </feature>

 <feature dump="cols">
